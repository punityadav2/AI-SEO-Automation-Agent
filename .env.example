# ============================================================
# AI SEO Automation Agent — Environment Variables Template
# Copy this file to .env and fill in your values
# ============================================================

# ---- Groq API (free at console.groq.com) ----
GROQ_API_KEY=your_groq_api_key_here

# ---- SerpAPI (free tier: 100 searches/month at serpapi.com) ----
SERPAPI_KEY=your_serpapi_key_here
# ---- GitHub (free token at github.com/settings/tokens) ----
GITHUB_TOKEN=ghp_your_github_token_here
GITHUB_REPO=your_username/your_repo_name       # e.g. john/seo-content

# ---- Google Sheets (Google Cloud Console → Sheets API) ----
GOOGLE_SHEET_ID=your_google_sheet_id_here      # From sheet URL: /spreadsheets/d/{ID}/

# ---- Google Search Console (Google Cloud Console → Search Console API) ----
GSC_SITE_URL=https://your-website.com/         # Must be verified in GSC

# ---- GMB / My Business API (Google Cloud Console → My Business API) ----
GMB_ACCOUNT_ID=accounts/your_account_id        # From GMB API accounts list
GMB_LOCATION_ID=locations/your_location_id     # From GMB API locations list

# ---- Content Target Settings ----
TARGET_CITY=Mumbai                             # For localised GMB keywords
TARGET_INDUSTRY=digital marketing             # Your business industry
